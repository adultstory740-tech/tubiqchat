// Prisma schema for chat session system
// Models: User, Session, Message, AdminSettings

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  sessions  Session[]
  minutes   Int      @default(0) // Remaining minutes in account
}

model Session {
  id             String    @id @default(uuid())
  user           User      @relation(fields: [userId], references: [id])
  userId         String
  startTime      DateTime
  lastMessageAt  DateTime
  endedAt        DateTime?
  messages       Message[]
  maxMessages    Int
  durationSec    Int // Session duration in seconds
  endedReason    String?
}

model Message {
  id         String   @id @default(uuid())
  session    Session  @relation(fields: [sessionId], references: [id])
  sessionId  String
  sender     String   // 'user' or 'ai'
  content    String
  createdAt  DateTime @default(now())
}

model AdminSettings {
  id                Int      @id @default(1)
  defaultDuration   Int      @default(600) // seconds
  defaultMaxMessages Int     @default(20)
  updatedAt         DateTime @updatedAt
}
